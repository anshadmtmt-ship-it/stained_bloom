# ═══════════════════════════════════════════════════════════════════════
# Stained Blooms — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════════════

# ─── Supabase ───────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project URL (safe to expose in frontend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/Publishable key (safe to expose — RLS policies restrict access)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── SECURITY NOTES ─────────────────────────────────────────────────────
# ✅ VITE_SUPABASE_URL              — Safe to expose in frontend bundles
# ✅ VITE_SUPABASE_PUBLISHABLE_KEY  — Safe to expose (protected by RLS)
#
# ❌ Service Role Key               — NEVER expose in frontend or commit to git
#    Only use Service Role Key in secure server-side scripts, never in Vite.
#
# ─── GITIGNORE THESE FILES ───────────────────────────────────────────────
# .env
# .env.local
# .env.production
# .env.*.local
